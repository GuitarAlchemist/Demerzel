(* Musicology Analysis Grammar — Streeling University *)
(* Department: World Music / Historical & Cultural Analysis *)
(* Weights are learned per department from research cycle outcomes *)
(* Consumed by: TARS WeightedGrammar, ga musicology agents *)
(* See: docs/superpowers/specs/2026-03-18-probabilistic-research-grammars-design.md *)

investigation ::= period style_analysis source_analysis conclude reflect
                | comparative_study source_analysis conclude reflect

(* Historical periods — Western and non-Western *)
period ::= medieval | renaissance | baroque | classical
         | romantic | modern | contemporary | non_western

non_western ::= east_asian | south_asian | middle_eastern
              | sub_saharan_african | latin_american | indigenous

(* Style analysis — structural and contextual dimensions *)
style_analysis ::= form texture dynamics instrumentation cultural_context
                 | form texture dynamics instrumentation

form ::= binary | ternary | rondo | sonata | theme_and_variations
       | through_composed | strophic | free_form

texture ::= monophonic | homophonic | polyphonic | heterophonic

dynamics ::= pianissimo | piano | mezzo | forte | fortissimo | terraced | graduated

(* Comparative study types *)
comparative_study ::= cross_period
                    | cross_genre
                    | cross_cultural
                    | influence_tracing
                    | reception_history

(* Source analysis — evidence types for musicological claims *)
source_analysis ::= primary_source | manuscript | recording
                  | interview | ethnographic_field | treatise
                  | iconographic | archival

(* Conclusions map to tetravalent logic *)
(* confirmed → T, disproven → F, insufficient_evidence → U, contested → C *)
conclude ::= confirmed
           | disproven
           | insufficient_evidence
           | contested
           | requires_further_research

(* Kuhnian reflection — paradigm awareness in musicology *)
reflect ::= consensus_view
           | emerging_revision
           | paradigm_challenge
           | interdisciplinary_insight
