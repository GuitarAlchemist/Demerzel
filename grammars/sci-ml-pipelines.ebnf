(* IxQL — ML Pipeline & Reactive Data Flow Grammar *)
(* Streeling University / ix Forge *)
(* Departments: computer-science, mathematics, psychohistory, cybernetics *)
(* Consumed by: ix-ml-builder skill, tars grammar distillation *)
(* Living grammar: evolves via research cycles + distillation *)
(* See: policies/grammar-evolution-policy.yaml *)

(* ============================================================ *)
(* 1. Pipeline Architecture — what to build                      *)
(* ============================================================ *)

pipeline ::= data_source preprocessing model evaluation deployment
           | data_source preprocessing model evaluation              (* no deploy — research mode *)
           | data_source model evaluation                            (* skip preprocessing — clean data *)
           | ensemble_pipeline                                       (* multiple models combined *)

ensemble_pipeline ::= pipeline "+" pipeline "=>" combiner

(* ============================================================ *)
(* 2. Data Sources — where to get data                           *)
(* ============================================================ *)

data_source ::= csv_file | json_file | parquet_file | database_query
              | api_endpoint | streaming_source | synthetic_generator
              | governance_state      (* Demerzel state/ files *)
              | git_history           (* commit logs, file changes *)
              | mcp_tool_output       (* output from MCP tools *)

data_shape ::= tabular | time_series | graph | text | image | audio | multimodal

(* ============================================================ *)
(* 3. Preprocessing — how to prepare                             *)
(* ============================================================ *)

preprocessing ::= cleaning transformation feature_engineering splitting
                | cleaning feature_engineering splitting
                | transformation splitting

cleaning ::= missing_value_handler outlier_detector deduplication
            | missing_value_handler deduplication
            | outlier_detector

missing_value_handler ::= drop | mean_impute | median_impute | knn_impute | model_impute
outlier_detector ::= zscore | iqr | isolation_forest | dbscan

transformation ::= normalization | standardization | log_transform
                 | pca_reduction | encoding | embedding

encoding ::= one_hot | label | ordinal | target | binary | frequency
embedding ::= word2vec | tfidf | sentence_transformer | domain_specific

feature_engineering ::= feature_selection | feature_creation | feature_interaction
                      | polynomial_features | time_features | lag_features

splitting ::= train_test_split | train_val_test_split | kfold_cv
            | stratified_split | time_series_split | group_split

(* ============================================================ *)
(* 4. Models — what to train                                     *)
(* ============================================================ *)

model ::= supervised_model | unsupervised_model | reinforcement_model
         | probabilistic_model | neural_model

supervised_model ::= classification_model | regression_model

classification_model ::= logistic_regression | decision_tree | random_forest
                       | gradient_boosting | svm | knn | naive_bayes
                       | neural_classifier

regression_model ::= linear_regression | ridge | lasso | elastic_net
                   | decision_tree_regressor | random_forest_regressor
                   | gradient_boosting_regressor | neural_regressor

unsupervised_model ::= clustering_model | dimensionality_model | anomaly_model

clustering_model ::= kmeans | dbscan_cluster | hierarchical | gaussian_mixture | spectral
dimensionality_model ::= pca | tsne | umap | autoencoder
anomaly_model ::= isolation_forest_detector | one_class_svm | autoencoder_detector

probabilistic_model ::= bayesian_linear | gaussian_process | hidden_markov
                      | variational_inference | mcmc_sampler

neural_model ::= mlp | cnn | rnn | lstm | transformer | graph_neural_network
               | diffusion_model | variational_autoencoder

reinforcement_model ::= q_learning | policy_gradient | actor_critic | mcts_agent

(* ============================================================ *)
(* 5. Evaluation — how to measure                                *)
(* ============================================================ *)

evaluation ::= metric_computation validation_strategy interpretation

metric_computation ::= classification_metrics | regression_metrics
                     | clustering_metrics | ranking_metrics | custom_metric

classification_metrics ::= accuracy | precision | recall | f1_score
                         | auc_roc | confusion_matrix | log_loss

regression_metrics ::= mse | rmse | mae | r_squared | mape | explained_variance

clustering_metrics ::= silhouette_score | calinski_harabasz | davies_bouldin
                     | adjusted_rand_index | normalized_mutual_info

validation_strategy ::= holdout | cross_validation | bootstrap
                      | time_series_validation | nested_cv

interpretation ::= feature_importance | shap_values | partial_dependence
                 | lime_explanation | attention_weights | residual_analysis

(* ============================================================ *)
(* 6. Deployment — where to ship                                 *)
(* ============================================================ *)

deployment ::= model_serialization serving_strategy monitoring

model_serialization ::= onnx | pickle | safetensors | rust_native | torchscript

serving_strategy ::= batch_inference | real_time_api | edge_deployment
                   | mcp_tool_integration   (* expose as MCP tool *)
                   | embedded_in_pipeline   (* inline in larger system *)

monitoring ::= drift_detection | performance_tracking | data_quality_check
             | alert_on_degradation | automatic_retrain_trigger

(* ============================================================ *)
(* 7. Governance Integration — Demerzel-specific                 *)
(* ============================================================ *)

(* ML pipelines are governed artifacts *)
governance_gate ::= data_provenance_check      (* where did training data come from? *)
                  | bias_assessment             (* fairness across stakeholders — Article 10 *)
                  | reversibility_check         (* can we roll back? — Article 3 *)
                  | confidence_calibration      (* are probabilities well-calibrated? *)
                  | explanation_requirement      (* can we explain predictions? — Article 2 *)

(* Pipeline conclusions map to tetravalent logic *)
(* If eval metrics meet threshold → T (model validated) *)
(* If eval metrics fail → F (model rejected) *)
(* If eval is inconclusive → U (need more data or different approach) *)
(* If eval shows contradictory results → C (model unstable, investigate) *)

conclude ::= validated | rejected | inconclusive | unstable | overfitting_detected

(* ============================================================ *)
(* 8. ix-Specific Pipeline Patterns                              *)
(* ============================================================ *)

(* These productions are distilled from ix Rust ML implementations *)
(* They will evolve as more ix pipelines are built *)

ix_pattern ::= karnaugh_optimization   (* Boolean function simplification *)
             | memristive_markov        (* conductance-weighted Markov chains *)
             | grammar_weight_learning  (* Bayesian grammar weight updates *)
             | governance_health_scorer (* cross-repo health metric computation *)
             | citation_power_law       (* power law detection in governance artifacts *)
             | compounding_dimension    (* fractal dimension D_c estimation *)

(* Combiner strategies for ensembles *)
combiner ::= voting | averaging | stacking | blending | boosting_cascade

(* ============================================================ *)
(* 9. I/O & Reactive Patterns                                    *)
(* ============================================================ *)

(* Input sources — reactive triggers for pipelines *)
reactive_source ::= websocket_source | file_watcher | sse_source
                  | webhook_source | cron_source | stdin_source
                  | message_queue | database_cdc | grpc_source

websocket_source ::= "websocket" "(" url "," channel? ")"
file_watcher     ::= "watch" "(" path_pattern ")" debounce?
sse_source       ::= "sse" "(" url ")"
webhook_source   ::= "webhook" "(" provider "," event_type ")"
cron_source      ::= "cron" "(" cron_expression ")"
stdin_source     ::= "stdin" format?
message_queue    ::= "subscribe" "(" broker "," topic ")"
database_cdc     ::= "cdc" "(" connection "," table ")"
grpc_source      ::= "grpc" "(" service "," method ")"

provider   ::= "github" | "discord" | "gitlab" | "generic"
event_type ::= string_literal
format     ::= "json" | "csv" | "text" | "binary"

(* Output sinks — where pipeline results go *)
output_sink ::= websocket_sink | file_sink | stdout_sink
              | http_post | mcp_register | discord_sink
              | github_sink | notification_sink

websocket_sink    ::= "push" "(" url "," channel? ")"
file_sink         ::= "write" "(" path "," format ")"
stdout_sink       ::= "stdout" format?
http_post         ::= "post" "(" url "," content_type ")"
mcp_register      ::= "mcp_tool" "(" tool_name "," description ")"
discord_sink      ::= "alert" "(" "discord" "," message_template ")"
github_sink       ::= "github" "(" action "," target ")"  (* action: issue, comment, pr *)
notification_sink ::= "notify" "(" channel "," message_template ")"

(* Flow control — reactive pipeline patterns *)
flow_control ::= fan_out | fan_in | filter_stage | throttle
               | retry_policy | circuit_breaker | window | debounce

fan_out         ::= "fan_out" "(" pipeline ("," pipeline)+ ")"
fan_in          ::= "fan_in" "(" source ("," source)+ ")" "=>" pipeline
filter_stage    ::= "filter" "(" predicate ")"
throttle        ::= "throttle" "(" rate "," time_unit ")"
retry_policy    ::= "retry" "(" max_attempts "," backoff_strategy ")"
circuit_breaker ::= "circuit_breaker" "(" max_failures "," reset_duration ")"
window          ::= "window" "(" duration "," aggregation ")"
debounce        ::= "debounce" "(" duration ")"

backoff_strategy ::= "constant" | "linear" | "exponential"
aggregation      ::= "count" | "sum" | "avg" | "min" | "max" | "collect"

(* Reactive pipeline — extends base pipeline with I/O *)
reactive_pipeline ::= reactive_source "=>" pipeline "=>" output_sink
                    | reactive_source "=>" flow_control
                    | pipeline "=>" output_sink   (* batch with explicit sink *)

(* ============================================================ *)
(* 10. MCP Orchestration — formerly MOG                          *)
(* ============================================================ *)

(* MCP tool invocation and orchestration folded into IxQL.        *)
(* Supersedes: docs/superpowers/specs/2026-03-21-mcp-orchestration-grammar-design.md *)
(* See: #109 for rationale.                                       *)

mcp_pipeline ::= mcp_step ("→" mcp_step)*

mcp_step ::= tool_invocation | parallel_tools | gated_tool
           | binding_step | conditional_step

tool_invocation ::= namespace "." method "(" arg_list? ")"
namespace       ::= identifier ("." identifier)*        (* e.g., context7, tars.grammar, ix.ml *)
arg_list        ::= expression ("," expression)*

parallel_tools ::= "parallel" "(" tool_invocation ("," tool_invocation)+ ")"
gated_tool     ::= "when" mog_guard ":" mcp_step
binding_step   ::= identifier "<-" mcp_step            (* bind result to variable *)
conditional_step ::= "if" mog_guard mcp_step ("else" mcp_step)?

(* Tetravalent gates — from MOG spec *)
mog_guard       ::= membership_test | semantic_predicate | guard_conjunction
membership_test ::= truth_value comparison_op? confidence_threshold
guard_conjunction ::= mog_guard "&&" mog_guard

truth_value          ::= "T" | "F" | "U" | "C"
comparison_op        ::= ">=" | "<=" | ">" | "<"
confidence_threshold ::= float_literal

semantic_predicate ::= "?" identifier "(" arg_list? ")"    (* custom predicate function *)

(* MCP-specific data flow *)
mcp_source ::= tool_invocation                              (* use tool output as data_source *)
mcp_sink   ::= "mcp_register" "(" tool_name "," description ")"
             | "mcp_invoke" "(" tool_invocation ")"

(* Compound phase — harvest learnings from MCP orchestration *)
mcp_compound ::= "compound" ":" compound_step+
compound_step ::= "harvest" expression
                | "promote" expression "if" mog_guard
                | "teach" expression "to" identifier
                | "log" expression

(* Examples:
   -- Governed MCP orchestration with tetravalent gates
   result <- context7.resolve("react")
   → when T >= 0.8: analysis <- tars.analyze(result)
   → when T >= 0.7: ix.train(analysis.features)
   → compound:
       harvest analysis.insights
       promote analysis if T >= 0.9
       teach analysis to seldon

   -- Parallel tool fanout
   parallel(
     tars.grammar.parse(input),
     ix.ml.classify(input),
     context7.query("react", input)
   ) → when T >= 0.7: merge_results → output_sink

   -- Reactive MCP: GitHub webhook triggers orchestration
   webhook(github, "push")
   → context7.resolve(repo)
   → when T >= 0.8: tars.analyze(changes)
   → ix.train(features)
   → alert(discord, "Analysis complete")
*)

(* ============================================================ *)
(* 11. Pipeline Identity & Routing                               *)
(* ============================================================ *)

(* Every pipeline has a formal identity for invocation *)
pipeline_declaration ::= "pipeline" handle display_name? "{" pipeline_body "}"

handle       ::= "@" identifier              (* formal address: @driver-cycle *)
display_name ::= string_literal              (* human-readable: "Driver Cycle" *)

pipeline_body ::= metadata? pipeline
metadata ::= version_decl? trigger_decl? description_decl?
version_decl     ::= "version:" semver
trigger_decl     ::= "trigger:" trigger_source
description_decl ::= "description:" string_literal

trigger_source ::= cron_source | webhook_source | file_watcher
                 | "manual" | "on_invoke"

(* ---- Routing Spectrum: Formal → Fuzzy ---- *)
(* Five levels, mapped to alignment confidence thresholds *)

(* L0: Exact handle — deterministic, machine-to-machine *)
invoke_exact ::= "invoke" handle ("(" arg_list? ")")?
               | "invoke" handle "=>" binding_step
(* Confidence: 1.0 — always proceed *)

(* L1: Alias — short names mapped to handles *)
invoke_alias ::= "invoke" "#" identifier ("(" arg_list? ")")?
(* Confidence: 0.95 — proceed autonomously *)
(* Alias registry: state/pipeline-aliases.json *)
(* Example: #audit → @gov-audit-001, #drive → @driver-cycle *)

(* L2: Pattern — glob match on handle namespace *)
invoke_pattern ::= "invoke" handle_glob ("(" arg_list? ")")?
handle_glob ::= "@" identifier "*"            (* @gov-* matches all governance pipelines *)
              | "@" "*" identifier "*"        (* @*audit* matches anything with "audit" *)
(* Confidence: 0.85 — proceed with note *)
(* Returns: array of matching pipelines → fan_out or pick best *)

(* L3: Semantic — natural language intent resolution *)
route_semantic ::= "route" "(" intent_description ")" routing_options?
intent_description ::= string_literal         (* "check governance health" *)
routing_options ::= "prefer:" handle          (* hint for disambiguation *)
                  | "fallback:" handle        (* if no match above threshold *)
                  | "threshold:" float_literal (* override default 0.7 *)
(* Confidence: 0.5-0.9 depending on cosine similarity *)
(* >= 0.7: proceed | < 0.7: confirm with caller | < 0.5: fallback or error *)

(* L4: Ambient — context-inferred, no explicit call *)
ambient_trigger ::= "ambient" "{" ambient_condition "=>" pipeline_ref "}"
ambient_condition ::= "when" predicate        (* when drift_detected *)
                    | "when" metric_check     (* when dc < 1.0 *)
                    | "when" signal_type      (* when conscience_signal fired *)
pipeline_ref ::= handle | "#" identifier | route_semantic
(* Confidence: 0.3-0.7 — always confirm unless pre-approved *)
(* Example: ambient { when belief.confidence < 0.5 => @weakness-probe } *)

(* Unified invocation — any level *)
invoke ::= invoke_exact | invoke_alias | invoke_pattern | route_semantic

(* Resolution cascade:
   1. L0 Exact:    @driver-cycle         → 1.0  → proceed
   2. L1 Alias:    #driver               → 0.95 → proceed
   3. L2 Pattern:  @gov-*                → 0.85 → proceed with note
   4. L3 Semantic: route("run audit")    → 0.5-0.9 → depends on score
   5. L4 Ambient:  (context triggers)    → 0.3-0.7 → confirm
   Confidence maps to alignment-policy.yaml thresholds *)

(* Cross-system resolution:
   @handle resolves differently per consumer:
   - ix CLI:      → pipeline file (pipelines/{handle}.ixql)
   - tars CE:     → F# method (IxqlBuilder.{handle}())
   - Claude Code: → skill (/demerzel {handle})
   - Assertions:  → test target (assert @handle { ... })
   - A2A:         → Agent Card capability
   All share the same registry: state/pipeline-registry.json *)

(* Pipeline registry: state/pipeline-registry.json
   Updated by MetaSync on every pipeline file change *)

(* Examples:
   pipeline @driver-cycle "Driver Cycle" {
     version: "1.0.0"
     trigger: cron("0 6 * * *")
     wake → invoke @gov-audit-001(level: "tier1")
         → invoke @weakness-probe
         → invoke @research-cycle(department: auto_select)
   }

   result <- invoke @gov-audit-001(level: "full")
   → when result.conclusion == U: invoke @weakness-probe(focus: result.gaps)

   → route("find related research")        -- resolves to @research-cycle
   → route("check for drift")              -- resolves to @metasync
*)

(* ============================================================ *)
(* 12. Evolution Hooks                                           *)
(* ============================================================ *)

(* This grammar evolves via: *)
(* 1. Research cycles in computer-science department *)
(* 2. Distillation from ix execution traces *)
(* 3. External grammar consumption (scikit-learn API, PyTorch, etc.) *)
(* 4. New ix pipeline patterns added as ix_pattern productions *)

(* Grammar health metrics: *)
(* production_utilization: which models/preprocessors are actually used? *)
(* weight_convergence: have preferences stabilized? *)
(* ix_pattern_count: are we capturing new patterns from ix? *)

(* ============================================================ *)
(* 12. Assertions — declarative pipeline correctness            *)
(* ============================================================ *)

(* Assertions are first-class IxQL constructs that express expectations *)
(* about data, model outputs, or governance state. They are evaluated  *)
(* at runtime and integrate with tetravalent logic: a failing assertion *)
(* produces F, an unresolvable assertion produces U or C.              *)
(*                                                                     *)
(* Constitutional basis:                                               *)
(*   Article 1  (Truthfulness) — assertions surface fabrication risks  *)
(*   Article 7  (Auditability) — assertion results are logged          *)
(*   Article 8  (Observability) — assertion health exposed as metrics  *)
(* See: tests/behavioral/ixql-assertions-cases.md                      *)

(* Top-level assertion declaration *)
assert ::= "assert" identifier ":" assertion_pipeline

(* An assertion pipeline applies one or more checks to a subject *)
assertion_pipeline ::= assertion_subject assertion_check+

(* Subject: what is being asserted over *)
assertion_subject ::= data_source         (* raw input data *)
                    | pipeline_expr        (* output of a pipeline *)
                    | model_stage          (* a trained model *)
                    | evaluation_stage     (* an evaluation result *)
                    | identifier           (* any named binding *)

(* A single check within an assertion pipeline *)
assertion_check ::= "assert_check" "(" assertion_condition ("," assertion_message)? ")"

(* The condition to test *)
assertion_condition ::= null_check
                      | type_check
                      | range_check
                      | metric_check
                      | truth_check
                      | schema_check
                      | governance_check
                      | custom_predicate

(* Null / completeness check *)
null_check ::= "not_null"
             | "no_nulls"                  (* alias *)
             | "null_fraction" "<" float_literal

(* Type conformance *)
type_check ::= "type" ":" data_shape

(* Numeric range — inclusive bounds *)
range_check ::= "range" ":" float_literal ".." float_literal
              | "min" ">=" float_literal
              | "max" "<=" float_literal
              | "mean" comparison_op float_literal

(* Metric threshold — assert an eval metric meets a threshold *)
metric_check ::= "metric" identifier comparison_op float_literal

(* Tetravalent truth check — assert a pipeline conclusion truth value *)
truth_check ::= "truth" comparison_op float_literal
              | "truth" "is" truth_value

(* Schema conformance — references a JSON Schema file or named schema *)
schema_check ::= "schema" ":" string_literal

(* Governance gate check — assert a governance gate passes *)
governance_check ::= "governance" ":" governance_gate
                   | "governed" governance_level    (* minimum governance level *)

(* Custom named predicate — extensible hook for domain-specific checks *)
custom_predicate ::= identifier ("(" arg_list ")")?

(* Optional human-readable failure message *)
assertion_message ::= "message" ":" string_literal

(* Assertion severity — influences runtime behavior on failure *)
assertion_severity ::= "error"    (* halt pipeline *)
                     | "warning"  (* log and continue *)
                     | "info"     (* trace only *)

(* Full assertion with severity *)
assertion_full ::= "assert" assertion_severity? identifier ":" assertion_pipeline

(* Assertion pipeline — combines assertion subject and chain of checks *)
(* with optional tetravalent conclusion *)
assertion_result ::= conclusion_binding? assertion_full
conclusion_binding ::= identifier "<-"

(* Examples:
   -- Assert training data has no nulls before training
   assert input_quality: csv("train.csv")
     assert_check(not_null, message: "Training data must be complete")
     assert_check(null_fraction < 0.01, message: "At most 1% nulls tolerated")

   -- Assert model meets accuracy threshold
   assert model_quality: random_forest → f1_score
     assert_check(metric f1_score >= 0.85, message: "F1 must be >= 0.85")
     assert_check(truth >= 0.9, message: "Must be T with confidence >= 0.9")

   -- Assert governance gate is present before deployment
   assert deployment_ready: random_forest → bias_assessment → real_time_api
     assert_check(governance: bias_assessment, message: "Bias check required")
     assert_check(governed standard, message: "Standard governance level required")

   -- Assert data shape is tabular
   assert data_shape: parquet("features.parquet")
     assert_check(type: tabular, message: "Model expects tabular input")
     assert_check(schema: "schemas/feature-schema.json")

   -- Assert with severity and binding
   quality_verdict <- assert error model_performance: csv("test.csv") → random_forest → f1_score
     assert_check(metric f1_score >= 0.80, message: "Minimum performance threshold")
*)

(* ============================================================ *)
(* 13. Traceability — Full Stack Audit Trail                     *)
(* ============================================================ *)

(* Every IxQL execution produces a trace chain from constitutional
   article down to C#/F# class method and back up. Article 7. *)

trace_record ::= trace_header trace_stages trace_summary

trace_header ::= pipeline_handle version timestamp trigger_source
               routing_level routing_confidence caller_context

trace_stages ::= trace_stage+
trace_stage ::= stage_name stage_type input_snapshot output_snapshot
              duration_ms conclusion runtime_binding?

(* Runtime binding: which actual code executed this stage *)
runtime_binding ::= mcp_binding | ce_binding | native_binding

mcp_binding    ::= "mcp" namespace "." method
                   "→" runtime_class                (* C#/F# class that handled it *)
ce_binding     ::= "tars_ce" method_name
                   "→" fsharp_module "." fsharp_function
native_binding ::= "ix" crate_name "::" rust_function

runtime_class   ::= dotnet_namespace "." class_name "." method_name
fsharp_module   ::= identifier ("." identifier)*
dotnet_namespace ::= identifier ("." identifier)*

(* Example trace:
   {
     "pipeline": "@gov-audit-001",
     "version": "1.0.0",
     "timestamp": "2026-03-24T18:00:00Z",
     "trigger": "invoke from @driver-cycle",
     "routing": { "level": "L0", "confidence": 1.0 },
     "stages": [
       {
         "name": "bias_assessment",
         "type": "governance_gate",
         "input": { "model_output": { "predictions": [...] } },
         "output": { "conclusion": "T", "confidence": 0.88 },
         "duration_ms": 142,
         "binding": {
           "type": "mcp",
           "tool": "tars.governance.check_bias",
           "runtime": "GA.Domain.Services.Governance.BiasAssessmentService.Evaluate()"
         }
       },
       {
         "name": "confidence_calibration",
         "type": "governance_gate",
         "binding": {
           "type": "tars_ce",
           "method": "gate ConfidenceCalibration",
           "runtime": "Tars.IxQL.Gates.ConfidenceGate.check()"
         }
       }
     ],
     "summary": {
       "conclusion": "T",
       "confidence": 0.85,
       "total_duration_ms": 1247,
       "stages_passed": 5,
       "stages_failed": 0,
       "deepest_binding": "GA.Domain.Core.Theory.Atonal.PitchClassSet.ComputeIcv()"
     }
   }
*)

(* Trace storage: state/traces/{handle}/{timestamp}.trace.json *)
(* Queryable by: handle, date range, conclusion, binding class *)

(* ============================================================ *)
(* 14. Auto-Distillation & Type Providers                        *)
(* ============================================================ *)

(* Pipelines learn from their own execution and generate types *)

(* Auto-distillation: traces feed back into grammar weights *)
distill ::= "distill" "(" trace_source "→" weight_target ")"

trace_source  ::= "traces" "(" handle "," time_range? ")"
weight_target ::= "grammar_weights" "(" grammar_file ")"
                | "production_weights" "(" production_name ")"

(* Example:
   distill(traces(@gov-audit-001, last: 30d) → grammar_weights("sci-ml-pipelines.ebnf"))
   -- Counts which stages are invoked most → adjusts production weights
   -- governance_gate used 500x → weight 0.85
   -- dimensionality_model used 2x → weight 0.02
*)

(* Auto-test: generate assertions from successful execution traces *)
auto_assert ::= "auto_assert" "(" handle "," capture_spec ")"
capture_spec ::= "capture:" "[" field_list "]"
               "when:" conclusion_filter
               "generate:" assertion_template

(* Example:
   auto_assert(@driver-cycle,
     capture: [input, stages.conclusion, summary.confidence],
     when: conclusion == T && confidence >= 0.8,
     generate: assert @driver-cycle-regression { given input → expect T }
   )
*)

(* Regression: run auto-generated assertions on grammar/pipeline changes *)
regression_suite ::= "regression" handle "{" assert+ "}"
(* Triggered by: on_grammar_change, on_pipeline_change, on_deploy *)

(* Type providers — F# inspired, IxQL native *)
(* Pipelines can declare dynamic types based on runtime data *)
type_provider ::= "type" identifier "=" "provided" "(" provider_source ")"

provider_source ::= "schema" "(" path ")"           (* JSON Schema → type *)
                  | "pipeline" "(" handle ")"        (* pipeline output shape → type *)
                  | "mcp_tool" "(" tool_name ")"     (* MCP tool response → type *)
                  | "database" "(" connection ")"    (* DB schema → type *)
                  | "csv_header" "(" path ")"        (* CSV columns → type *)

(* Example:
   type AuditResult = provided(pipeline(@gov-audit-001))
   -- Compiler/LSP knows: AuditResult has .conclusion, .confidence, .stages[]
   -- Auto-complete works on AuditResult fields

   type ChordAnalysis = provided(mcp_tool("ga.chord.analyze"))
   -- Type inferred from MCP tool's output schema
   -- ChordAnalysis has .root, .quality, .intervals[], .pitchClassSet

   type FeatureRow = provided(csv_header("data/features.csv"))
   -- Columns become typed fields
*)

(* Cross-language type mapping:
   IxQL provided type  →  F# record (tars CE)
   IxQL provided type  →  C# record/class (ga)
   IxQL provided type  →  Rust struct (ix)
   IxQL provided type  →  JSON Schema (validation)
   All generated from the same source via type_provider *)

