(* Acoustics & Physical Modeling Grammar — Streeling University *)
(* Department: Acoustics / Physics of Sound *)
(* Weights are learned per department from simulation and measurement outcomes *)
(* Consumed by: TARS WeightedGrammar, ix numerical models, ga instrument agents *)
(* See: docs/superpowers/specs/2026-03-18-probabilistic-research-grammars-design.md *)

investigation ::= phenomenon modeling measurement conclude
                | instrument_physics modeling measurement conclude

(* Acoustic phenomena — what we are studying *)
phenomenon ::= standing_wave | harmonic_series | resonance
             | interference | diffraction | damping
             | reflection | refraction | absorption

(* Modeling approaches — how we represent the physics *)
modeling ::= analytical_solution
           | numerical_simulation
           | dimensional_analysis
           | perturbation_theory
           | finite_element
           | boundary_element

numerical_simulation ::= fdtd | fem | bem | spectral_method | modal_synthesis

(* Measurement — how we observe and quantify *)
measurement ::= frequency_measurement | amplitude_measurement | phase_measurement
              | spectrum_analysis | time_domain | frequency_domain
              | impulse_response | transfer_function

spectrum_analysis ::= fft | wavelet | cepstral | spectrogram | power_spectral_density

(* Instrument physics — physical sound sources *)
instrument_physics ::= string_vibration | air_column | membrane
                     | plate | coupled_oscillator | resonant_body

string_vibration ::= fixed_fixed | fixed_free | damped_string | stiff_string

air_column ::= open_open | open_closed | conical | cylindrical

(* Conclusions map to tetravalent logic *)
(* model_validated → T, model_rejected → F, insufficient_data → U, anomalous → C *)
conclude ::= model_validated
           | model_rejected
           | insufficient_data
           | anomalous
           | refine_model
           | discover_phenomenon
