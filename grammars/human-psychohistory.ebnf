(* Psychohistory Grammar — Streeling University *)
(* Department: Psychohistory / Statistical Governance Mechanics *)
(* Weights are learned per department from governance cycle predictions *)
(* Consumed by: TARS WeightedGrammar, Demerzel governance analysis, Seldon Plan *)
(* See: docs/superpowers/specs/2026-03-18-probabilistic-research-grammars-design.md *)

investigation ::= observation system_model statistical_method prediction conclude
                | governance_metric statistical_method prediction conclude

(* Prediction types — what the model forecasts *)
prediction ::= trend_extrapolation
             | phase_transition_detection
             | crisis_anticipation
             | bifurcation_analysis
             | stability_assessment
             | emergence_detection

(* Statistical methods — tools for analysis *)
statistical_method ::= power_law_fit
                     | distribution_analysis
                     | correlation_detection
                     | time_series
                     | monte_carlo
                     | bayesian_inference
                     | causal_inference

time_series ::= arima | exponential_smoothing | spectral | changepoint_detection

(* System models — how to represent the governed system *)
system_model ::= agent_based | mean_field | network
               | hierarchical | fractal | cellular_automaton
               | coupled_oscillator

network ::= scale_free | small_world | random | preferential_attachment

(* Governance metrics — what Demerzel tracks *)
governance_metric ::= health_score
                    | citation_rate
                    | belief_freshness
                    | compounding_dimension
                    | ergol_lolli_ratio
                    | conscience_discomfort
                    | policy_compliance_rate
                    | artifact_promotion_velocity

(* Conclusions map to tetravalent logic *)
(* prediction_confirmed → T, prediction_falsified → F, *)
(* insufficient_history → U, seldon_crisis → C *)
conclude ::= prediction_confirmed
           | prediction_falsified
           | insufficient_history
           | seldon_crisis
           | revise_model
           | spawn_investigation

(* Meta: Seldon Plan integration — crisis response *)
crisis_response ::= adjust_weights | introduce_perturbation | escalate_to_human | activate_contingency
