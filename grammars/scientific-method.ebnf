(* Universal Scientific Method Grammar — Streeling University *)
(* Each production has a weight learned per department *)
(* Governance artifact — consumed by TARS WeightedGrammar *)
(* See: docs/superpowers/specs/2026-03-18-probabilistic-research-grammars-design.md *)

investigation ::= observe hypothesize predict test conclude reflect
                | observe hypothesize test conclude reflect
                | observe analogize transfer validate reflect

(* How to form hypotheses *)
hypothesize ::= inductive
              | deductive
              | abductive
              | analogical
              | combinatorial

(* How to test *)
test ::= empirical
       | formal_proof
       | simulation
       | thought_experiment
       | cross_validation
       | adversarial

(* How to conclude — maps to tetravalent logic *)
(* confirm → T, refute → F, insufficient → U, contradictory → C *)
(* revise → re-enter cycle, discover_question → spawn new investigation *)
conclude ::= confirm
           | refute
           | insufficient
           | contradictory
           | revise
           | discover_question

(* Meta-reasoning — Kuhnian paradigm detection layer *)
(* normal_progress → routine weight update *)
(* anomaly_detected → silence_discomfort signal *)
(* paradigm_tension → confidence_discomfort signal *)
(* paradigm_shift → /demerzel promote with human review *)
reflect ::= normal_progress
          | anomaly_detected
          | paradigm_tension
          | paradigm_shift
