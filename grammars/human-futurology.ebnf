(* Futurology Grammar — Streeling University *)
(* Department: futurology *)
(* Consumed by: Demerzel governance (trend prediction), psychohistory *)
(* See: state/streeling/departments/futurology.department.json *)
(* Each production has a weight learned per investigation type *)

(* ============================================================ *)
(* 1. Forecasting Methods — how to predict                      *)
(* ============================================================ *)

investigation ::= observe forecast evaluate conclude reflect
                | observe scan extrapolate validate reflect
                | observe model simulate compare reflect

forecast ::= trend_extrapolation
           | scenario_planning
           | delphi_method
           | cross_impact_analysis
           | technology_roadmap
           | backcasting
           | wild_card_analysis

(* ============================================================ *)
(* 2. Scanning — what to look for                               *)
(* ============================================================ *)

scan ::= signal_detection
       | weak_signal_amplification
       | trend_identification
       | discontinuity_search
       | horizon_scan

signal_type ::= strong_signal    (* obvious, well-documented trend *)
              | weak_signal      (* early indicator, ambiguous *)
              | wild_card        (* low probability, high impact *)
              | seed_of_change   (* nascent, transformative potential *)
              | driver           (* force shaping the future *)

horizon ::= near_horizon     (* 0-3 years, high confidence *)
           | mid_horizon      (* 3-10 years, moderate confidence *)
           | far_horizon      (* 10-30 years, speculative *)
           | deep_horizon     (* 30+ years, visionary *)

(* ============================================================ *)
(* 3. Scenario Construction — alternative futures                *)
(* ============================================================ *)

scenario ::= axis_one "x" axis_two "->" quadrant_narrative

axis_type ::= technological | social | economic | environmental
            | political | cultural | demographic

quadrant_narrative ::= optimistic_scenario
                     | pessimistic_scenario
                     | transformative_scenario
                     | continuation_scenario

scenario_quality ::= internally_consistent
                   | provocative
                   | plausible
                   | decision_relevant

(* ============================================================ *)
(* 4. Evidence and Assessment                                    *)
(* ============================================================ *)

evidence ::= quantitative_trend
           | expert_opinion
           | analogical_precedent
           | technology_maturity_assessment
           | social_indicator
           | patent_analysis

(* Map to tetravalent logic *)
(* confirm → T: trend validated with multiple signals *)
(* refute → F: disconfirming evidence found *)
(* insufficient → U: weak signals only, need more data *)
(* contradictory → C: conflicting signals, fork in the road *)

conclude ::= confirm | refute | insufficient | contradictory
           | fork_detected | emergence_spotted

reflect ::= normal_progress
           | paradigm_shift_approaching
           | wild_card_triggered
           | scenario_invalidated
