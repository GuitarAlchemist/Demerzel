-- Context Budget: The context engine (#163) as an IxQL pipeline
-- Demonstrates: IxQL managing AI context windows as a governed resource
-- Flow: task → artifact discovery → relevance scoring → budget allocation → selection
-- Real artifacts: policies/context-management-policy.yaml, state/, schemas/

-- Step 1: Parse incoming task and extract intent signals
task <- ix.io.read("state/driver/current-task.json")

task_signals <- task
  → tars.extract(fields: [
      "description",
      "repo_scope",
      "artifact_types_needed",
      "expected_depth",
      "constitutional_articles_referenced"
    ])
  → tars.classify(
      categories: ["governance", "research", "debugging", "creation", "audit"],
      method: "semantic"
    )

-- Step 2: Discover candidate artifacts across the ecosystem
candidates <- fan_out(
    -- Governance artifacts (constitutions, policies, personas)
    when task_signals.category in ["governance", "audit"]:
      parallel(
        ix.io.glob("constitutions/*.md"),
        ix.io.glob("policies/*.yaml"),
        ix.io.glob("personas/*.persona.yaml")
      ),

    -- State artifacts (beliefs, conscience, evolution)
    when task_signals.category in ["governance", "debugging"]:
      parallel(
        ix.io.glob("state/beliefs/*.belief.json"),
        ix.io.glob("state/conscience/signals/*.signal.json"),
        ix.io.glob("state/evolution/*.evolution.json")
      ),

    -- Research artifacts (grammars, courses, weights)
    when task_signals.category == "research":
      parallel(
        ix.io.glob("grammars/*.ebnf"),
        ix.io.glob("state/streeling/departments/*.department.json"),
        ix.io.glob("state/streeling/courses/{dept}/en/*.md")
      ),

    -- Code artifacts (from consumer repos)
    when task_signals.repo_scope:
      fan_out(
        task_signals.repo_scope.map(repo =>
          ix.io.gh("contents", repo: repo, path: task_signals.relevant_paths)
        )
      ),

    -- Always include: recent manifests, health scores
    ix.io.read("state/driver/health-scores.json"),
    ix.io.read("state/manifests/latest.manifest.json")
  )

-- Step 3: Score each candidate for relevance to the task
scored <- candidates
  → fan_out(
      candidates.map(artifact =>
        parallel(
          -- Semantic relevance: does content match task intent?
          tars.score_relevance(artifact, task_signals.description)
            → { dimension: "semantic", score: relevance_score },
          -- Recency: how fresh is this artifact?
          ix.ml.compute(metric: "freshness_score", input: artifact.last_modified)
            → { dimension: "recency", score: freshness },
          -- Citation frequency: is this artifact frequently referenced?
          ix.ml.compute(metric: "citation_count", input: artifact.path)
            → { dimension: "citation", score: normalized_citations },
          -- Constitutional weight: does task reference articles this artifact covers?
          tars.match_articles(artifact, task_signals.constitutional_articles_referenced)
            → { dimension: "constitutional", score: article_match_score }
        )
        → ix.ml.weighted_sum(
            semantic:       0.40,
            recency:        0.20,
            citation:       0.20,
            constitutional: 0.20
          )
        → { artifact: artifact, relevance: combined_score }
      )
    )
  → ix.ml.rank(by: "relevance", order: "descending")

-- Step 4: Budget allocation — fit artifacts into context window
budget <- ix.io.read("state/driver/context-budget.json")
  → { max_tokens: budget.max_tokens, reserved: budget.system_prompt_tokens }

available_tokens <- budget.max_tokens - budget.reserved

selected <- scored
  → ix.ml.knapsack(
      items: scored,
      capacity: available_tokens,
      value_key: "relevance",
      weight_key: "token_count",
      constraints: {
        -- Always include: active constitution articles referenced by task
        must_include: scored → filter(dimension == "constitutional" && score >= 0.8),
        -- Never exceed 30% budget on any single artifact
        max_per_item: available_tokens * 0.30,
        -- Reserve 20% for response generation
        response_reserve: available_tokens * 0.20
      }
    )

-- Step 5: Assemble context package with governance checks
context_package <- selected
  → fan_out(
      selected.map(s =>
        ix.io.read(s.artifact.path)
        → tars.summarize(
            max_tokens: s.allocated_tokens,
            preserve: ["key_definitions", "active_rules", "confidence_values"]
          )
      )
    )
  → tars.assemble(
      order: "constitutional_first",           -- Constitution at top, details below
      include_metadata: true                   -- Add relevance scores as comments
    )
  → bias_assessment                           -- Article 10: did we exclude any stakeholder?
  → explanation_requirement                    -- Article 2: explain selection rationale

-- Step 6: Persist selection metadata for learning
write("state/oversight/context-selections/{date}-{task_id}.json", {
    task: task_signals,
    candidates_found: candidates.count,
    candidates_scored: scored.count,
    artifacts_selected: selected.count,
    total_tokens: selected.sum(token_count),
    budget_utilization: selected.sum(token_count) / available_tokens,
    top_relevance: selected.top(1).relevance,
    bottom_relevance: selected.bottom(1).relevance
  })

  → compound:
      harvest selected.relevance_patterns
      -- Learn which artifacts actually helped (feedback from task outcome)
      when task.outcome_available:
        selected → filter(was_useful) → weights.boost(0.05)
        selected → filter(was_unused) → weights.decay(0.02)
      promote context_selection_model if T >= 0.9 && tasks_completed >= 20
      teach relevance_patterns to seldon
      log context_budget_cycle to "state/evolution/"
