{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "course-production.schema.json",
  "title": "Course Production Pipeline Run",
  "description": "Log entry for a complete course production pipeline: research → outline → content → translation → review → publish",
  "type": "object",
  "required": [
    "pipeline_id",
    "department",
    "research_cycle_id",
    "module_id",
    "status",
    "phases",
    "timestamp"
  ],
  "properties": {
    "pipeline_id": {
      "type": "string",
      "description": "Unique pipeline identifier: cp-{department}-{date}-{sequence}"
    },
    "department": {
      "type": "string",
      "description": "Streeling University department producing this course"
    },
    "research_cycle_id": {
      "type": "string",
      "description": "Research cycle that produced the source findings"
    },
    "module_id": {
      "type": "string",
      "description": "Module identifier for the produced course (e.g., mus-002-voice-leading)"
    },
    "status": {
      "type": "string",
      "enum": ["in_progress", "review_pending", "published", "rejected", "failed"],
      "description": "Current pipeline status"
    },
    "phases": {
      "type": "object",
      "required": ["research", "outline", "content"],
      "properties": {
        "research": {
          "type": "object",
          "properties": {
            "completed": { "type": "boolean" },
            "belief_value": { "type": "string", "enum": ["T", "F", "U", "C"] },
            "belief_confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
          },
          "required": ["completed"]
        },
        "outline": {
          "type": "object",
          "properties": {
            "completed": { "type": "boolean" },
            "sections": { "type": "integer", "minimum": 1 },
            "estimated_duration": { "type": "string" }
          },
          "required": ["completed"]
        },
        "content": {
          "type": "object",
          "properties": {
            "completed": { "type": "boolean" },
            "word_count": { "type": "integer", "minimum": 0 },
            "exercises": { "type": "integer", "minimum": 0 }
          },
          "required": ["completed"]
        },
        "translation": {
          "type": "object",
          "properties": {
            "completed": { "type": "boolean" },
            "languages": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "required": ["completed"]
        },
        "review": {
          "type": "object",
          "properties": {
            "completed": { "type": "boolean" },
            "reviewer": { "type": "string" },
            "verdict": { "type": "string", "enum": ["approved", "revise", "reject"] },
            "feedback": { "type": "string" }
          },
          "required": ["completed"]
        },
        "publish": {
          "type": "object",
          "properties": {
            "completed": { "type": "boolean" },
            "paths": {
              "type": "array",
              "items": { "type": "string" },
              "description": "File paths where course was published"
            }
          },
          "required": ["completed"]
        }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "total_duration_seconds": { "type": "integer", "minimum": 0 },
        "tokens_used": { "type": "integer", "minimum": 0 },
        "revision_count": { "type": "integer", "minimum": 0 }
      }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When this pipeline run completed or was last updated"
    }
  },
  "additionalProperties": false
}
