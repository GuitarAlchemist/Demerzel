{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "trigger.schema.json",
  "title": "Driver Trigger",
  "description": "An event or condition that initiates a driver cycle",
  "type": "object",
  "required": ["type", "repo", "priority", "timestamp"],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "ci_failure",
        "issue_opened",
        "issue_reopened",
        "push",
        "dependabot_pr",
        "discussion_created",
        "submodule_drift",
        "self_initiated",
        "scheduled"
      ],
      "description": "The kind of event that triggered the driver"
    },
    "repo": {
      "type": "string",
      "enum": ["demerzel", "ix", "tars", "ga"],
      "description": "Which repository the trigger originates from"
    },
    "ref": {
      "type": "string",
      "description": "Git ref associated with the trigger, if applicable"
    },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"],
      "description": "Urgency level of this trigger"
    },
    "details": {
      "type": "object",
      "additionalProperties": true,
      "description": "Arbitrary payload with trigger-specific details"
    },
    "rationale": {
      "type": "string",
      "description": "Justification for self_initiated triggers"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When the trigger was created"
    }
  },
  "additionalProperties": false
}
